# Get key: https://trello.com/app-key
# Token: same page → generate token (read your boards)
# Board id: open a board, URL is trello.com/b/BOARD_ID/… (8-char) or use the 24-char id from the board menu → More → Print and export
TRELLO_API_KEY=
TRELLO_TOKEN=
# One board or comma-separated: board1,board2
TRELLO_BOARD_ID=

# Optional: cache Trello id list (minutes). Default 15
# TRELLO_CACHE_MINUTES=15

# Optional: skip check for one command: set SKIP_TRELLO_VALIDATE=1
# (Or use git commit with hooks disabled: git -c core.hooksPath=/dev/null commit …)
